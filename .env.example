PORT=3000
PUBLIC_BASE_URL=https://your-domain.com

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Alternative to the 3 values above:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_GRAPH_API_VERSION=v23.0

WORKING_MODEL_AUDIO_MEDIA_ID=replace-with-uploaded-audio-media-id
TERMS_AND_CONDITIONS_URL=https://your-domain.com/terms-and-conditions
WHATSAPP_DRY_RUN=true

ADMIN_DEFAULT_REVIEWER=ops-team
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
SESSION_SECRET=replace-with-long-random-secret
SESSION_TTL_HOURS=12
SECONDARY_NOTIFICATION_PHONE=
TERMS_REMINDER_DELAY_HOURS=24
TERMS_REMINDER_CHECK_INTERVAL_MINUTES=30
TERMS_REMINDER_RESUME_KEYWORD=continue
TERMS_REMINDER_TEMPLATE_NAME=
TERMS_REMINDER_TEMPLATE_LANGUAGE=en
PULSO_HUB_BOT_SYNC_URL=
PULSO_HUB_BOT_SYNC_SECRET=
MEDIA_STORAGE_DIR=./storage/media
