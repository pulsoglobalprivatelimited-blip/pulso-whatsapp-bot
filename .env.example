PORT=3000
PUBLIC_BASE_URL=https://your-domain.com

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Alternative to the 3 values above:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-waba-id
# Optional: use a management token with whatsapp_business_management permission for listing/registering numbers.
WHATSAPP_MANAGEMENT_ACCESS_TOKEN=
WHATSAPP_REGISTER_PIN=123456

# Optional second WhatsApp sender for provider support.
# Keep WHATSAPP_PHONE_NUMBER_ID for the existing joining/onboarding bot.
PROVIDER_SUPPORT_WHATSAPP_PHONE_NUMBER_ID=replace-with-provider-support-phone-number-id
PROVIDER_SUPPORT_BOT_WHATSAPP_NUMBER=917736129809
PROVIDER_SUPPORT_JOINING_CHATBOT_URL=https://wa.me/917736167744
PROVIDER_SUPPORT_CUSTOMER_CARE_WHATSAPP_URL=https://wa.me/919446600809
PROVIDER_SUPPORT_PHONE=8714105333
PROVIDER_SUPPORT_ANDROID_APP_URL=https://play.google.com/store/apps/details?id=com.pulso.global
PROVIDER_SUPPORT_IOS_APP_URL=https://apps.apple.com/in/app/pulso/id6757874217

WORKING_MODEL_AUDIO_MEDIA_ID=replace-with-uploaded-audio-media-id
TERMS_AND_CONDITIONS_URL=https://your-domain.com/terms-and-conditions
WHATSAPP_DRY_RUN=true

ADMIN_DEFAULT_REVIEWER=ops-team
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
# Optional replacement for ADMIN_USERNAME / ADMIN_PASSWORD.
# Use one JSON line in production env settings.
ADMIN_USERS_JSON=[{"username":"admin","password":"replace-with-strong-password","role":"super_admin","active":true},{"username":"ops-team","password":"replace-with-reviewer-password","role":"reviewer","active":true}]
SESSION_SECRET=replace-with-long-random-secret
SESSION_TTL_HOURS=12
SECONDARY_NOTIFICATION_PHONE=
CERTIFICATE_REVIEW_TEMPLATE_NAME=certificate_review_alert
CERTIFICATE_REVIEW_TEMPLATE_LANGUAGE=en
TERMS_REMINDER_DELAY_HOURS=24
TERMS_REMINDER_CHECK_INTERVAL_MINUTES=30
TERMS_REMINDER_RESUME_KEYWORD=continue
TERMS_REMINDER_TEMPLATE_NAME=
TERMS_REMINDER_TEMPLATE_LANGUAGE=en
PULSO_HUB_BOT_SYNC_URL=
PULSO_HUB_BOT_SYNC_SECRET=
MEDIA_STORAGE_DIR=./storage/media

# IVR / WhatsApp handoff
IVR_STAFF_PHONE=918714105666
IVR_RECRUITMENT_WHATSAPP_NUMBER=919633108778
IVR_WEBHOOK_SECRET=
IVR_WEBHOOK_ALLOWED_IPS=
IVR_JOB_WHATSAPP_TEMPLATE_NAME_EN=
IVR_JOB_WHATSAPP_TEMPLATE_NAME_ML=
IVR_JOB_WHATSAPP_TEMPLATE_LANGUAGE_EN=en
IVR_JOB_WHATSAPP_TEMPLATE_LANGUAGE_ML=ml
