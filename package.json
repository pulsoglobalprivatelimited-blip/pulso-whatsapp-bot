{
  "name": "pulso-whatsapp-bot",
  "version": "1.0.0",
  "description": "Pulso WhatsApp onboarding bot for care providers from Meta ads",
  "main": "src/server.js",
  "scripts": {
    "db:init": "node src/scripts/initDb.js",
    "media:backfill": "node src/scripts/backfillMediaToStorage.js",
    "pulso-hub:sync:completed": "node src/scripts/syncCompletedProvidersToPulsoHub.js",
    "terms:accept:reconcile": "node src/scripts/reconcileAcceptedTermsProviders.js",
    "terms:reminder:current-backfill": "node src/scripts/sendCurrentWaitingTermsReminderBackfill.js",
    "terms:reminder:backfill": "node src/scripts/sendLegacyTermsReminderBackfill.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "multer": "^2.0.0"
  }
}
